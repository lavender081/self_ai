{
  "functions": {
    "api/chat.py": {
      "runtime": "python3.11",
      "outputDirectory": "api"
    }
  },
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/chat.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/chat.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
